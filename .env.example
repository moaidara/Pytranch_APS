# Variables à définir en local (User Secrets) ou en prod (variables d'environnement).
# Ne jamais committer de valeurs réelles sur GitHub.

# Environnement (Development | Staging | Production)
# ASPNETCORE_ENVIRONMENT=Development

# Base de données PostgreSQL 
# En ASP.NET, les deux-points (:) sont remplacés par __ dans les variables d'env.
# ConnectionStrings:DefaultConnection  →  ConnectionStrings__DefaultConnection
# ConnectionStrings__DefaultConnection=Host=db;Port=5432;Database=paytranch;Username=postgres;Password=VOTRE_MOT_DE_PASSE

# Exemple format Npgsql / PostgreSQL :
# ConnectionStrings__DefaultConnection=Host=db;Port=5432;Database=paytranch;Username=postgres;Password=postgres
